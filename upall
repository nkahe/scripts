#!/bin/zsh

# Update various software.

set -e

has() {
  command -v "$@" &> /dev/null
}

if has dnf; then
  sudo dnf upgrade
fi

# Flatpaks
if has flatpak; then
  echo -e "Updating flatpaks...\n"
  if flatpak info org.signal.Signal >/dev/null 2>&1; then
    flatpak update --assumeyes org.signal.Signal
  fi
fi

# Appimages

