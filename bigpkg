#!/usr/bin/env bash

set -euo pipefail

DEFAULT_N=100
N="$DEFAULT_N"
REVERSE=0
PIP_MODE=0
PKG_MANAGER=""

show_help() {
  cat <<EOF
Usage: $("basename" "$0") [OPTIONS]

List installed rpm or deb packages by size depending if rpm or dpkg is
  installed or alternatively Python pip packages.

Options:
  -n <number>       Number of packages to show (used for tail).
                    Default: ${DEFAULT_N}
  -r, --reverse     Reverse the final output order.
  -p, --pip         List installed Python packages by size.
  -h, --help        Show this help and exit

Examples:
  $("basename" "$0")
  $("basename" "$0") -n 20
  $("basename" "$0") -n 50 --reverse
EOF
}

# argument parsing
while [[ $# -gt 0 ]]; do
  case "$1" in
    -n)
      if [[ -z "${2:-}" || "$2" =~ ^- ]]; then
        echo "Error: -n requires a numeric argument." >&2
        show_help
        exit 1
      fi
      N="$2"
      shift 2
      ;;
    -r|--reverse)
      REVERSE=1
      shift
      ;;
    -p|--pip)
      PIP_MODE=1
      shift
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    *)
      echo "Error: Unknown option: $1" >&2
      show_help
      exit 1
      ;;
  esac
done

list_rpm_packages() {
  rpm -qa --queryformat="%{SIZE} %{NAME} %{VERSION}\n"
}

list_dpkg_packages() {
  dpkg-query -W -f='${Installed-Size} ${Package} ${Version}\n' \
    | awk '{print $1 * 1024, $2, $3}'
}

list_pip_packages() {
  if ! command -v pip >/dev/null 2>&1; then
    echo "Error: pip is not installed." >&2
    exit 1
  fi

  python3 - <<'PY'
import importlib.metadata as md

rows = []
for dist in md.distributions():
    name = dist.metadata.get("Name") or dist.metadata.get("Summary") or "unknown"
    version = dist.version or ""
    size = 0
    for file in dist.files or []:
        try:
            size += dist.locate_file(file).stat().st_size
        except OSError:
            pass
    rows.append((size, name, version))

for size, name, version in rows:
    print(f"{size} {name} {version}")
PY
}

if [[ "$PIP_MODE" -eq 0 ]]; then
  if command -v rpm >/dev/null 2>&1; then
    PKG_MANAGER="rpm"
  elif command -v dpkg >/dev/null 2>&1; then
    PKG_MANAGER="dpkg"
  else
    echo "Error: neither rpm nor dpkg is installed." >&2
    exit 1
  fi
fi

# build pipeline explicitly for clarity
pipeline() {
  if [[ "$PIP_MODE" -eq 1 ]]; then
    list_pip_packages
  elif [[ "$PKG_MANAGER" == "dpkg" ]]; then
    list_dpkg_packages
  else
    list_rpm_packages
  fi \
    | sort --key=1 --numeric-sort \
    | tail --lines="$N" \
    | awk '{size=$1; $1=""; print size, $0}' \
    | numfmt --field=1 --to=iec --suffix=B
}

if [[ "$REVERSE" -eq 1 ]]; then
  pipeline
else
  pipeline | tac
fi
